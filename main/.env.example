# 이 파일은 예시입니다. 실제 값을 채운 뒤 파일명을 .env로 저장하고
# 로컬 환경변수(또는 IDE의 Run Configuration, direnv 등)로 주입해 사용하세요.
# .env 파일 자체는 Git에 커밋되지 않습니다.

# ── 활성 프로필 (local | prod) ──────────────────────────
SPRING_PROFILES_ACTIVE=local

# ── Supabase PostgreSQL Session Pooler (Phase 1) ───────
# Supabase Dashboard > Connect > Session pooler의 값을 사용하세요.
# host 예시: aws-0-ap-northeast-2.pooler.supabase.com
# Session mode는 5432 포트를 사용합니다(6543은 Transaction mode).
# username 형식: postgres.<project-ref>
SUPABASE_DB_POOLER_HOST=
SUPABASE_DB_POOLER_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USERNAME=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_SSL_MODE=require

# ── CORS 허용 Origin (Phase 2) ──────────────────────────
# 프론트엔드 개발 서버 주소를 쉼표(,)로 구분하여 나열하세요.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── JWT 인증 (Phase 4에서 사용 예정) ────────────────────
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION=
JWT_REFRESH_TOKEN_EXPIRATION=

# ── Supabase Storage (Phase 6에서 사용 예정) ────────────
SUPABASE_STORAGE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# ── OpenAI API (Phase 10) ──────────────────────────────
OPENAI_API_KEY=
# 아래 둘은 변경하지 않으려면 주석 처리된 채로 두세요(값이 ""로 설정되면
# 기본값 대신 빈 문자열이 사용되어 버립니다). 기본값은 gpt-4o-mini / https://api.openai.com/v1 입니다.
# OPENAI_MODEL=
# OPENAI_BASE_URL=
